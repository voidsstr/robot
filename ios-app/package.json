{
  "name": "robot-control",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "build:ios": "bash scripts/build-and-submit.sh",
    "submit:ios": "eas submit --platform ios --latest --non-interactive",
    "ota:production": "npx --yes eas-cli@latest update --branch production --auto",
    "ota:preview": "npx --yes eas-cli@latest update --branch preview --auto"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-haptics": "~15.0.8",
    "expo-location": "^55.1.10",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-ble-plx": "^3.5.0",
    "react-native-maps": "^1.27.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~14.0.6",
    "typescript": "~5.9.2"
  }
}
